<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.edgevideoanalysis.ai.mapper.InferenceRecordMapper">

    <!-- 按灯杆ID和时间范围查询推理记录 -->
    <select id="selectByLampIdAndTimeRange" resultType="com.edgevideoanalysis.ai.entity.InferenceRecord">
        SELECT * FROM t_inference_record
        WHERE lamp_id = #{lampId}
        AND inference_time BETWEEN #{startTime} AND #{endTime}
        ORDER BY inference_time DESC
    </select>

</mapper>
